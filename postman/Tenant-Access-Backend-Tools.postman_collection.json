{
  "info": {
    "name": "Tenant Access Backend Tools",
    "description": "Postman collection for testing all backend MCP-style chatbot tools through /chatbot/query. Run Connect Tenant first so tenantToken and tenantBaseUrl are populated.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "backendUrl", "value": "http://localhost:5000" },
    { "key": "clientId", "value": "YOUR_SAP_CLIENT_ID" },
    { "key": "clientSecret", "value": "YOUR_SAP_CLIENT_SECRET" },
    { "key": "tokenUrl", "value": "https://YOUR_TENANT.authentication.REGION.hana.ondemand.com/oauth/token" },
    { "key": "tenantBaseUrlInput", "value": "https://YOUR_TENANT.it-cpi001.cfapps.REGION.hana.ondemand.com" },
    { "key": "tenantToken", "value": "" },
    { "key": "tenantBaseUrl", "value": "" },
    { "key": "queueName", "value": "JMS_Queue_100_DLQ" },
    { "key": "targetQueueName", "value": "JMS_Queue_100" },
    { "key": "messageId", "value": "PASTE_MESSAGE_ID" },
    { "key": "packageName", "value": "All" },
    { "key": "iflowName", "value": "All" },
    { "key": "email", "value": "your.email@example.com" },
    { "key": "mplId", "value": "PASTE_MPL_ID" },
    { "key": "logStart", "value": "PASTE_LOG_START" },
    { "key": "attachmentTimestamp", "value": "PASTE_ATTACHMENT_TIMESTAMP" }
  ],
  "item": [
    {
      "name": "00 - Connect Tenant",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{backendUrl}}/connectTenant",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"clientId\": \"{{clientId}}\",\n  \"clientSecret\": \"{{clientSecret}}\",\n  \"tokenUrl\": \"{{tokenUrl}}\",\n  \"baseUrl\": \"{{tenantBaseUrlInput}}\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('connected', function () { pm.response.to.have.status(200); });",
              "const data = pm.response.json();",
              "if (data.token) pm.collectionVariables.set('tenantToken', data.token);",
              "if (data.baseUrl) pm.collectionVariables.set('tenantBaseUrl', data.baseUrl);"
            ]
          }
        }
      ]
    },
    {
      "name": "00 - Capabilities",
      "request": {
        "method": "GET",
        "url": "{{backendUrl}}/chatbot/capabilities"
      }
    },
    { "name": "01 - get_tenant_overview", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": "{{backendUrl}}/chatbot/query", "body": { "mode": "raw", "raw": "{\n  \"prompt\": \"show tenant overview for past hour\",\n  \"token\": \"{{tenantToken}}\",\n  \"baseUrl\": \"{{tenantBaseUrl}}\",\n  \"packages\": []\n}" } } },
    { "name": "02 - get_message_status_overview", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": "{{backendUrl}}/chatbot/query", "body": { "mode": "raw", "raw": "{\n  \"prompt\": \"show message status overview for past hour\",\n  \"token\": \"{{tenantToken}}\",\n  \"baseUrl\": \"{{tenantBaseUrl}}\",\n  \"packages\": []\n}" } } },
    { "name": "03 - get_monitoring_logs", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": "{{backendUrl}}/chatbot/query", "body": { "mode": "raw", "raw": "{\n  \"prompt\": \"show failed messages in past hour\",\n  \"token\": \"{{tenantToken}}\",\n  \"baseUrl\": \"{{tenantBaseUrl}}\",\n  \"packages\": []\n}" } } },
    { "name": "04 - get_monitoring_overview", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": "{{backendUrl}}/chatbot/query", "body": { "mode": "raw", "raw": "{\n  \"prompt\": \"show monitoring overview for past hour\",\n  \"token\": \"{{tenantToken}}\",\n  \"baseUrl\": \"{{tenantBaseUrl}}\",\n  \"packages\": []\n}" } } },
    { "name": "05 - get_integration_content", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": "{{backendUrl}}/chatbot/query", "body": { "mode": "raw", "raw": "{\n  \"prompt\": \"show integration content artifacts\",\n  \"token\": \"{{tenantToken}}\",\n  \"baseUrl\": \"{{tenantBaseUrl}}\",\n  \"packages\": []\n}" } } },
    { "name": "06 - list_packages", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": "{{backendUrl}}/chatbot/query", "body": { "mode": "raw", "raw": "{\n  \"prompt\": \"list packages\",\n  \"token\": \"{{tenantToken}}\",\n  \"baseUrl\": \"{{tenantBaseUrl}}\",\n  \"packages\": []\n}" } } },
    { "name": "07 - list_artifacts", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": "{{backendUrl}}/chatbot/query", "body": { "mode": "raw", "raw": "{\n  \"prompt\": \"list artifacts in {{packageName}} package\",\n  \"token\": \"{{tenantToken}}\",\n  \"baseUrl\": \"{{tenantBaseUrl}}\",\n  \"packages\": []\n}" } } },
    { "name": "08 - get_security_materials", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": "{{backendUrl}}/chatbot/query", "body": { "mode": "raw", "raw": "{\n  \"prompt\": \"show security materials\",\n  \"token\": \"{{tenantToken}}\",\n  \"baseUrl\": \"{{tenantBaseUrl}}\",\n  \"packages\": []\n}" } } },
    { "name": "09 - get_keystores", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": "{{backendUrl}}/chatbot/query", "body": { "mode": "raw", "raw": "{\n  \"prompt\": \"show keystore entries\",\n  \"token\": \"{{tenantToken}}\",\n  \"baseUrl\": \"{{tenantBaseUrl}}\",\n  \"packages\": []\n}" } } },
    { "name": "10 - get_pgp_keys", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": "{{backendUrl}}/chatbot/query", "body": { "mode": "raw", "raw": "{\n  \"prompt\": \"get PGP keys in pubring for runtime cloudintegration\",\n  \"token\": \"{{tenantToken}}\",\n  \"baseUrl\": \"{{tenantBaseUrl}}\",\n  \"packages\": []\n}" } } },
    { "name": "11 - get_access_policies", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": "{{backendUrl}}/chatbot/query", "body": { "mode": "raw", "raw": "{\n  \"prompt\": \"show access policies\",\n  \"token\": \"{{tenantToken}}\",\n  \"baseUrl\": \"{{tenantBaseUrl}}\",\n  \"packages\": []\n}" } } },
    { "name": "12 - get_user_roles", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": "{{backendUrl}}/chatbot/query", "body": { "mode": "raw", "raw": "{\n  \"prompt\": \"show user roles\",\n  \"token\": \"{{tenantToken}}\",\n  \"baseUrl\": \"{{tenantBaseUrl}}\",\n  \"packages\": []\n}" } } },
    { "name": "13 - get_data_stores", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": "{{backendUrl}}/chatbot/query", "body": { "mode": "raw", "raw": "{\n  \"prompt\": \"show data stores\",\n  \"token\": \"{{tenantToken}}\",\n  \"baseUrl\": \"{{tenantBaseUrl}}\",\n  \"packages\": []\n}" } } },
    { "name": "14 - get_variables", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": "{{backendUrl}}/chatbot/query", "body": { "mode": "raw", "raw": "{\n  \"prompt\": \"show variables\",\n  \"token\": \"{{tenantToken}}\",\n  \"baseUrl\": \"{{tenantBaseUrl}}\",\n  \"packages\": []\n}" } } },
    { "name": "15 - get_number_ranges", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": "{{backendUrl}}/chatbot/query", "body": { "mode": "raw", "raw": "{\n  \"prompt\": \"show number ranges\",\n  \"token\": \"{{tenantToken}}\",\n  \"baseUrl\": \"{{tenantBaseUrl}}\",\n  \"packages\": []\n}" } } },
    { "name": "16 - get_partner_directory", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": "{{backendUrl}}/chatbot/query", "body": { "mode": "raw", "raw": "{\n  \"prompt\": \"show partner directory entries\",\n  \"token\": \"{{tenantToken}}\",\n  \"baseUrl\": \"{{tenantBaseUrl}}\",\n  \"packages\": []\n}" } } },
    { "name": "17 - get_message_locks", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": "{{backendUrl}}/chatbot/query", "body": { "mode": "raw", "raw": "{\n  \"prompt\": \"show message locks\",\n  \"token\": \"{{tenantToken}}\",\n  \"baseUrl\": \"{{tenantBaseUrl}}\",\n  \"packages\": []\n}" } } },
    { "name": "18 - get_system_logs", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": "{{backendUrl}}/chatbot/query", "body": { "mode": "raw", "raw": "{\n  \"prompt\": \"show system logs\",\n  \"token\": \"{{tenantToken}}\",\n  \"baseUrl\": \"{{tenantBaseUrl}}\",\n  \"packages\": []\n}" } } },
    { "name": "19 - get_usage_details", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": "{{backendUrl}}/chatbot/query", "body": { "mode": "raw", "raw": "{\n  \"prompt\": \"show current month usage details\",\n  \"token\": \"{{tenantToken}}\",\n  \"baseUrl\": \"{{tenantBaseUrl}}\",\n  \"packages\": []\n}" } } },
    { "name": "20 - get_connectivity_tests", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": "{{backendUrl}}/chatbot/query", "body": { "mode": "raw", "raw": "{\n  \"prompt\": \"show connectivity tests\",\n  \"token\": \"{{tenantToken}}\",\n  \"baseUrl\": \"{{tenantBaseUrl}}\",\n  \"packages\": []\n}" } } },
    { "name": "21 - export_monitoring_excel", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": "{{backendUrl}}/chatbot/query", "body": { "mode": "raw", "raw": "{\n  \"prompt\": \"export monitoring excel for package {{packageName}} artifact {{iflowName}} status All past hour\",\n  \"token\": \"{{tenantToken}}\",\n  \"baseUrl\": \"{{tenantBaseUrl}}\",\n  \"packages\": []\n}" } } },
    { "name": "22 - download_payload_zip", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": "{{backendUrl}}/chatbot/query", "body": { "mode": "raw", "raw": "{\n  \"prompt\": \"download payload zip for package {{packageName}} artifact {{iflowName}} status All past hour\",\n  \"token\": \"{{tenantToken}}\",\n  \"baseUrl\": \"{{tenantBaseUrl}}\",\n  \"packages\": []\n}" } } },
    { "name": "23 - download_payload_file", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": "{{backendUrl}}/chatbot/query", "body": { "mode": "raw", "raw": "{\n  \"prompt\": \"download payload file mplId {{mplId}} logStart {{logStart}} attachmentTimestamp {{attachmentTimestamp}}\",\n  \"token\": \"{{tenantToken}}\",\n  \"baseUrl\": \"{{tenantBaseUrl}}\",\n  \"packages\": []\n}" } } },
    { "name": "24 - send_monitoring_email", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": "{{backendUrl}}/chatbot/query", "body": { "mode": "raw", "raw": "{\n  \"prompt\": \"send monitoring email to {{email}} for package {{packageName}} artifact {{iflowName}} status All past hour\",\n  \"token\": \"{{tenantToken}}\",\n  \"baseUrl\": \"{{tenantBaseUrl}}\",\n  \"packages\": []\n}" } } },
    { "name": "25 - list_jms_queues", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": "{{backendUrl}}/chatbot/query", "body": { "mode": "raw", "raw": "{\n  \"prompt\": \"show all JMS queues\",\n  \"token\": \"{{tenantToken}}\",\n  \"baseUrl\": \"{{tenantBaseUrl}}\",\n  \"packages\": []\n}" } } },
    { "name": "26 - list_jms_messages", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": "{{backendUrl}}/chatbot/query", "body": { "mode": "raw", "raw": "{\n  \"prompt\": \"show messages in JMS queue {{queueName}}\",\n  \"token\": \"{{tenantToken}}\",\n  \"baseUrl\": \"{{tenantBaseUrl}}\",\n  \"packages\": []\n}" } } },
    { "name": "27 - get_jms_resources", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": "{{backendUrl}}/chatbot/query", "body": { "mode": "raw", "raw": "{\n  \"prompt\": \"show JMS broker resources\",\n  \"token\": \"{{tenantToken}}\",\n  \"baseUrl\": \"{{tenantBaseUrl}}\",\n  \"packages\": []\n}" } } },
    { "name": "28 - move_jms_message", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": "{{backendUrl}}/chatbot/query", "body": { "mode": "raw", "raw": "{\n  \"prompt\": \"move JMS message {{messageId}} from {{queueName}} to {{targetQueueName}}\",\n  \"token\": \"{{tenantToken}}\",\n  \"baseUrl\": \"{{tenantBaseUrl}}\",\n  \"packages\": []\n}" } } },
    { "name": "29 - retry_jms_message", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": "{{backendUrl}}/chatbot/query", "body": { "mode": "raw", "raw": "{\n  \"prompt\": \"retry JMS message {{messageId}} from {{queueName}}\",\n  \"token\": \"{{tenantToken}}\",\n  \"baseUrl\": \"{{tenantBaseUrl}}\",\n  \"packages\": []\n}" } } },
    { "name": "30 - delete_jms_message", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": "{{backendUrl}}/chatbot/query", "body": { "mode": "raw", "raw": "{\n  \"prompt\": \"delete JMS message {{messageId}} from {{queueName}}\",\n  \"token\": \"{{tenantToken}}\",\n  \"baseUrl\": \"{{tenantBaseUrl}}\",\n  \"packages\": []\n}" } } },
    { "name": "31 - trigger_cpi_flow", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": "{{backendUrl}}/chatbot/query", "body": { "mode": "raw", "raw": "{\n  \"prompt\": \"trigger CPI flow for package {{packageName}} artifact {{iflowName}} status All past hour\",\n  \"token\": \"{{tenantToken}}\",\n  \"baseUrl\": \"{{tenantBaseUrl}}\",\n  \"packages\": []\n}" } } }
  ]
}
